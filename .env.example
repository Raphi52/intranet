# Portail Amitel — configuration de déploiement Docker.
# Copiez ce fichier en .env (NON versionné) et adaptez AVANT le premier démarrage :
#   cp .env.example .env   &&   docker compose up -d --build

# --- Compte administrateur amorcé au PREMIER démarrage --------------------
# Sans ces deux variables, un mot de passe ALÉATOIRE est généré et affiché
# une seule fois dans les logs (docker compose logs). Définissez-les pour
# maîtriser le compte admin initial. Changez le mot de passe !
ADMIN_EMAIL=admin@amitel.fr
ADMIN_PASSWORD=changez-ce-mot-de-passe

# --- Réseau / divers -------------------------------------------------------
# Port publié sur l'hôte (le conteneur écoute en interne sur 3000).
HOST_PORT=8080
# Fuseau horaire pour l'horodatage des signatures (la base reste en UTC).
TZ=Europe/Paris
